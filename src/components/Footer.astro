---
const today = new Date();
---

<footer>
	<hr class="divider-single" />
	<p>&copy; {today.getFullYear()} KI Post — Unabhängige KI-Berichterstattung für die Schweiz</p>
</footer>
<style>
	footer {
		padding: 1rem 0 2rem;
		text-align: center;
		font-size: 0.85rem;
		color: #666;
	}
	.divider-single {
		border: none;
		border-top: 1px solid #111;
		margin: 0 0 1rem 0;
	}
</style>
